{
  "name": "@nepali-cal/datepicker",
  "version": "1.0.1",
  "description": "Fully customizable Nepali (Bikram Sambat) DatePicker for React. Theming, composition, and BS/AD switching out of the box.",
  "author": {
    "name": "Apsan",
    "url": "https://apsan.com.np"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": {
      "default": "./dist/styles.css"
    },
    "./tailwind": "./tailwind.preset.js"
  },
  "sideEffects": [
    "*.css"
  ],
  "keywords": [
    "nepali",
    "datepicker",
    "bikram-sambat",
    "calendar",
    "nepal",
    "react",
    "typescript",
    "BS",
    "AD",
    "customizable",
    "theming"
  ],
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "@nepali-cal/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "lightningcss": "^1.32.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts --external react && node ./scripts/build-css.mjs",
    "dev": "tsup src/index.tsx --format cjs,esm --dts --watch"
  },
  "license": "MIT",
  "files": [
    "dist",
    "tailwind.preset.js"
  ]
}
